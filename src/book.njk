---
layout: base.njk
title: Book a Shoot
description: Book Dreamy Shots for your next event. Select a date and time to get started.
permalink: "/book/"
bookingPage: true
---
<div class="ds-booking-wrap">

  <div class="ds-booking-steps-bar" id="ds-booking-steps-bar">
    <div class="ds-booking-step-item ds-step-active" id="step-indicator-1">
      <span class="ds-step-num">1</span>
      <span class="ds-step-label">Date &amp; Time</span>
    </div>
    <div class="ds-step-connector" aria-hidden="true"></div>
    <div class="ds-booking-step-item" id="step-indicator-2">
      <span class="ds-step-num">2</span>
      <span class="ds-step-label">Your Details</span>
    </div>
  </div>

  {# ── Step 1: Date & Time ── #}
  <div id="ds-booking-step1" class="ds-booking-step-panel">

    <div class="ds-booking-step-header">
      <h1 class="ds-booking-title" data-pagefind-weight="10">Book a Shoot</h1>
      <p class="ds-booking-intro">
        Pick a date for your event, then choose Wency's arrival and finish time.
      </p>
    </div>

    <div class="ds-cal" id="ds-calendar" role="group" aria-label="Date picker">
      <div class="ds-cal-header">
        <button class="ds-cal-nav" id="ds-cal-prev" type="button" aria-label="Previous month">
          <i class="bi bi-chevron-left" aria-hidden="true"></i>
        </button>
        <span class="ds-cal-month-label" id="ds-cal-month-label"></span>
        <button class="ds-cal-nav" id="ds-cal-next" type="button" aria-label="Next month">
          <i class="bi bi-chevron-right" aria-hidden="true"></i>
        </button>
      </div>
      <div class="ds-cal-weekdays" aria-hidden="true">
        <span>Mon</span><span>Tue</span><span>Wed</span>
        <span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
      </div>
      <div class="ds-cal-days" id="ds-cal-days" role="grid" aria-label="Calendar days"></div>
    </div>

    <div class="ds-time-pickers" id="ds-time-pickers" hidden>
      <p class="ds-tg-instruction" id="ds-tg-instruction"></p>
      <div class="ds-tg-wrap" id="ds-tg-wrap">
        <div class="ds-tg" id="ds-time-grid" role="grid" aria-label="Time selection"></div>
      </div>
    </div>

    <div class="ds-booking-actions">
      <div class="ds-btn-tooltip-wrap" id="ds-continue-wrap">
        <button class="ds-booking-btn" id="ds-booking-continue" type="button" disabled>
          Continue <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </button>
      </div>
    </div>

  </div>

  {# ── Step 2: Details ── #}
  <div id="ds-booking-step2" class="ds-booking-step-panel" hidden>

    <div class="ds-booking-summary-bar" id="ds-booking-summary" aria-live="polite"></div>

    <div class="ds-booking-step-header">
      <h2 class="ds-booking-title">Your details</h2>
      <p class="ds-booking-intro">A few more things before we confirm your shoot.</p>
    </div>

    <form class="ds-booking-form" id="ds-booking-form"
          name="booking" method="POST"
          data-netlify="true" netlify-honeypot="bot-field"
          novalidate>

      <p hidden aria-hidden="true">
        <label>Do not fill this in: <input name="bot-field" tabindex="-1" autocomplete="off"/></label>
      </p>
      <input type="hidden" name="date" id="b-date">
      <input type="hidden" name="startTime" id="b-start-time">
      <input type="hidden" name="endTime" id="b-end-time">

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-name">Contact name <span class="ds-required-mark" aria-hidden="true">*</span></label>
        <input class="ds-form-input" type="text" id="b-name" name="name"
               autocomplete="name" required>
      </div>

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-phone">Phone number <span class="ds-required-mark" aria-hidden="true">*</span></label>
        <input class="ds-form-input" type="tel" id="b-phone" name="phone"
               autocomplete="tel" required>
      </div>

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-email">Email <span class="ds-required-mark" aria-hidden="true">*</span></label>
        <input class="ds-form-input" type="email" id="b-email" name="email"
               autocomplete="email" required>
      </div>

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-address">Event address <span class="ds-required-mark" aria-hidden="true">*</span></label>
        <input class="ds-form-input" type="text" id="b-address" name="address"
               autocomplete="street-address" required>
      </div>

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-org">Organisation name</label>
        <input class="ds-form-input" type="text" id="b-org" name="organisation"
               autocomplete="organization">
      </div>

      <div class="ds-form-group">
        <label class="ds-form-label" for="b-abn">ABN</label>
        <input class="ds-form-input" type="text" id="b-abn" name="abn"
               inputmode="numeric" pattern="[0-9\s]{9,14}">
      </div>

      <div class="ds-form-group">
        <p class="ds-form-label">Will food and drink be provided?</p>
        <div class="ds-toggle-group" role="radiogroup" aria-label="Food and drink provided">
          <label class="ds-toggle-opt">
            <input type="radio" name="food" value="yes">
            <span>Yes</span>
          </label>
          <label class="ds-toggle-opt">
            <input type="radio" name="food" value="no">
            <span>No</span>
          </label>
        </div>
      </div>

      <div class="ds-booking-actions">
        <button type="button" class="ds-booking-btn-back" id="ds-booking-back">
          <i class="bi bi-arrow-left" aria-hidden="true"></i> Back
        </button>
        <div class="ds-payment-btns">
          <div class="ds-pay-now-wrap">
            <button type="button" class="ds-booking-btn" disabled aria-disabled="true">
              Pay Now
              <i class="bi bi-lock-fill" aria-hidden="true" style="font-size:0.8em;"></i>
            </button>
            <span class="ds-coming-soon-badge">Coming Soon</span>
          </div>
          <button type="submit" class="ds-booking-btn">
            Pay by Invoice
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
          </button>
        </div>
      </div>

    </form>
  </div>

  {# ── Confirmation ── #}
  <div id="ds-booking-confirm" class="ds-booking-step-panel" hidden>
    <div class="ds-booking-confirm-inner">
      <div class="ds-booking-confirm-icon">
        <i class="bi bi-check-circle" aria-hidden="true"></i>
      </div>
      <h2 class="ds-booking-confirm-title">You're booked in.</h2>
      <p class="ds-booking-confirm-msg">
        Wency will be in touch within 24 hours to confirm the details and
        send over the invoice. Keep an eye on your inbox.
      </p>
      <div class="ds-booking-confirm-date" id="ds-confirm-date" aria-live="polite"></div>

      <div class="ds-add-to-cal">
        <button type="button" class="ds-add-cal-btn" id="ds-ics-btn">
          <i class="bi bi-calendar-arrow-down" aria-hidden="true"></i>
          Add to Calendar
        </button>
        <a class="ds-add-cal-btn ds-add-cal-google" id="ds-gcal-btn" href="#" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="4" y="8" width="40" height="36" rx="3" fill="#fff"/>
            <rect x="4" y="8" width="40" height="11" rx="3" fill="#1a73e8"/>
            <rect x="4" y="14" width="40" height="5" fill="#1a73e8"/>
            <rect x="13" y="2" width="5" height="12" rx="2.5" fill="#ea4335"/>
            <rect x="30" y="2" width="5" height="12" rx="2.5" fill="#ea4335"/>
            <text x="24" y="38" font-family="Arial,sans-serif" font-size="15" font-weight="bold" fill="#1a73e8" text-anchor="middle">31</text>
          </svg>
          Google Calendar
        </a>
      </div>

      <a href="/" class="ds-cta" style="margin-top:1.5rem;">
        Back to home <i class="bi bi-arrow-right" aria-hidden="true" style="font-size:0.75em;"></i>
      </a>
    </div>
  </div>

</div>
