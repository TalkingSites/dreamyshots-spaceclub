<nav class="ds-nav" aria-label="Main navigation">
  <a href="/" class="ds-nav-brand"><i class="bi bi-camera2" aria-hidden="true" style="color:var(--ds-accent);vertical-align:middle;font-size:1.4em;"></i> {{ site.name }}</a>

  <div class="ds-nav-right">
    <ul class="ds-nav-links" id="ds-nav-links">
      {% for item in navbar %}
      {% if item.bookingCta %}
      <li>
        <a href="{{ site.bookingUrl }}"
           class="ds-nav-book"
           target="_blank"
           rel="noopener noreferrer">
          {{ item.title }}
          <i class="bi bi-arrow-up-right" aria-hidden="true" style="font-size:0.7em;"></i>
        </a>
      </li>
      {% else %}
      <li>
        <a href="{{ item.href }}"
           {% if page.url == item.href or (item.href != "/" and page.url and page.url.startsWith(item.href)) %}
             class="active" aria-current="page"
           {% endif %}>
          {{ item.title }}
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>

    <!-- Search -->
    <button class="ds-nav-icon-btn" id="ds-nav-search"
            aria-label="Search" onclick="openSearch()">
      <i class="bi bi-search" aria-hidden="true"></i>
    </button>

    <!-- Theme toggle -->
    <button class="ds-nav-icon-btn" id="ds-theme-toggle"
            aria-label="Toggle light/dark mode">
      <i class="bi bi-sun" id="ds-theme-icon" aria-hidden="true"></i>
    </button>

    <!-- Mobile menu toggle -->
    <button class="ds-nav-toggle" id="ds-nav-toggle"
            aria-label="Toggle menu" aria-expanded="false">
      <i class="bi bi-list" aria-hidden="true"></i>
    </button>
  </div>
</nav>

<!-- Search modal -->
<div class="modal fade" id="searchModal" tabindex="-1"
     aria-labelledby="searchModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title" id="searchModalLabel">
          <i class="bi bi-search me-2" aria-hidden="true"></i>Search
        </h5>
        <button type="button" class="btn-close"
                data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2">
        <div class="mb-3">
          <input type="text"
                 class="form-control form-control-lg"
                 id="searchInput"
                 placeholder="Search shoots, events..."
                 oninput="performSearch()"/>
        </div>
        <div id="searchResults" style="max-height:400px;overflow-y:auto;"></div>
      </div>
    </div>
  </div>
</div>
