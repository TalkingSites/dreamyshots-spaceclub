RADICALE_URL=https://cal.talkingsites.org
RADICALE_USER=dreamyshots
RADICALE_PASSWORD=your-radicale-password-here
# Optional — defaults to /dreamyshots/calendar/
# RADICALE_CALENDAR_PATH=/dreamyshots/calendar/
# Optional — defaults to Australia/Sydney
# BOOKING_TZ=Australia/Sydney

# Stripe — get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
# Your Stripe Price ID for the hourly rate (from Products in the Stripe dashboard)
STRIPE_PRICE_ID=price_your-price-id-here
